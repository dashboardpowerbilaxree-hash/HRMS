generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  name      String
  role      String   @default("admin")
  createdAt DateTime @default(now())
}

model Firm {
  id           String   @id @default(cuid())
  code         String   @unique
  name         String
  description  String?
  address      String?
  contactPhone String?
  contactEmail String?
  logo         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Location {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Employee {
  id               String      @id @default(cuid())
  employeeId       String      @unique
  fullName         String
  mobile           String?
  email            String?
  firm             String
  location         String
  salaryType       String      @default("hourly")
  monthlySalary    Float       @default(0)
  dailyRate        Float       @default(0)
  hourlyRate       Float       @default(0)
  overtimeRate     Float       @default(0)
  employmentType   String      @default("Full Time")
  shiftStart       String      @default("10:00")
  shiftEnd         String      @default("19:00")
  shiftHours       Float       @default(9)
  designation      String?
  department       String?
  joiningDate      DateTime    @default(now())
  address          String?
  bankName         String?
  bankAccount      String?
  bankIfsc         String?
  panNumber        String?
  aadhaarNumber    String?
  pfNumber         String?
  esiNumber        String?
  status           String      @default("active")
  reportingManager String?
  emergencyContact String?
  profilePhoto     String?
  documents        String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  attendance       Attendance[]
  payrolls         Payroll[]
  leaves           Leave[]
  overtimes        Overtime[]
  salaryHistory    SalaryHistory[]
  notifications    Notification[]
  advances         Advance[]
}

model Attendance {
  id             String    @id @default(cuid())
  employeeId     String
  date           DateTime
  checkIn        String?
  checkOut       String?
  totalHours     Float     @default(0)
  status         String    @default("present")
  lateEntry      Boolean   @default(false)
  halfDay        Boolean   @default(false)
  overtimeHours  Float     @default(0)
  earlyOut       Boolean   @default(false)
  isHoliday      Boolean   @default(false)
  isWeeklyOff    Boolean   @default(false)
  isSunday       Boolean   @default(false)
  isPH           Boolean   @default(false)
  sundayHours    Float     @default(0)
  phHours        Float     @default(0)
  remarks        String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  employee       Employee  @relation(fields: [employeeId], references: [employeeId])
}

model Holiday {
  id          String   @id @default(cuid())
  name        String
  date        DateTime
  type        String   @default("national")
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Leave {
  id          String   @id @default(cuid())
  employeeId  String
  type        String
  startDate   DateTime
  endDate     DateTime
  days        Float    @default(1)
  reason      String?
  status      String   @default("pending")
  approvedBy  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  employee    Employee @relation(fields: [employeeId], references: [employeeId])
}

model Overtime {
  id          String   @id @default(cuid())
  employeeId  String
  date        DateTime
  hours       Float    @default(0)
  rate        Float    @default(0)
  amount      Float    @default(0)
  isHoliday   Boolean  @default(false)
  isSunday    Boolean  @default(false)
  status      String   @default("approved")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  employee    Employee @relation(fields: [employeeId], references: [employeeId])
}

model Payroll {
  id               String   @id @default(cuid())
  employeeId       String
  month            Int
  year             Int
  monthlySalary    Float    @default(0)
  hourlyRate       Float    @default(0)
  totalWorkedHrs   Float    @default(0)
  otHours          Float    @default(0)
  otRate           Float    @default(0)
  otAmount         Float    @default(0)
  sundayHrs        Float    @default(0)
  sundayCount      Float    @default(0)
  sundayEarnings   Float    @default(0)
  phHours          Float    @default(0)
  totalHrs         Float    @default(0)
  presentDays      Float    @default(0)
  absentDays       Float    @default(0)
  holidayDays      Float    @default(0)
  paidLeaves       Float    @default(0)
  grossSalary      Float    @default(0)
  tdsDeduction     Float    @default(0)
  loanDeduction    Float    @default(0)
  advanceDeduction Float    @default(0)
  securityDeposit  Float    @default(0)
  otherDeductions  Float    @default(0)
  totalDeductions  Float    @default(0)
  arrear           Float    @default(0)
  bonus            Float    @default(0)
  incentive        Float    @default(0)
  netSalary        Float    @default(0)
  status           String   @default("generated")
  generatedAt      DateTime @default(now())
  approvedBy       String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  employee         Employee @relation(fields: [employeeId], references: [employeeId])
}

model SalaryHistory {
  id          String   @id @default(cuid())
  employeeId  String
  month       Int
  year        Int
  netSalary   Float    @default(0)
  createdAt   DateTime @default(now())
  employee    Employee @relation(fields: [employeeId], references: [employeeId])
}

model Notification {
  id         String    @id @default(cuid())
  employeeId String?
  title      String
  message    String
  type       String    @default("info")
  read       Boolean   @default(false)
  createdAt  DateTime  @default(now())
  employee   Employee? @relation(fields: [employeeId], references: [employeeId])
}

model Department {
  id          String   @id @default(cuid())
  name        String   @unique
  code        String   @unique
  description String?
  head        String?
  location    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  module    String
  details   String?
  userId    String?
  createdAt DateTime @default(now())
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model Advance {
  id          String   @id @default(cuid())
  employeeId  String
  amount      Float
  reason      String
  date        DateTime
  month       Int
  year        Int
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  employee    Employee @relation(fields: [employeeId], references: [employeeId])
}
